rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is a registered Admin
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email == 'admin@arham.com' || 
              request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2' ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2' ||
        (
          // Allow referral bonus credit from another user
          request.resource.data.diff(resource.data).affectedKeys().hasAny(['walletBalance', 'referralCount', 'notifications']) &&
          request.resource.data.walletBalance >= resource.data.walletBalance &&
          request.resource.data.referralCount == resource.data.referralCount + 1
        )
      );
      allow delete: if request.auth != null && request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2';
      
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2');
      }
    }

    // Product collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Banners
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Coupons
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // App Metadata
    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings (Lucky Wheel, etc)
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Referral Tasks (Fallback for security rules)
    match /referral_tasks/{taskId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null && (resource.data.referrerUid == request.auth.uid || isAdmin());
    }

    // Orders
    match /orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
    
    // Error Logs
    match /error_logs/{logId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    
    // Block all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
