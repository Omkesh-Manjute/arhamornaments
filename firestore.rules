rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is a registered Admin
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email == 'admin@arham.com' || 
              request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2' ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2');
      allow read, write: if request.auth != null && request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2';
      
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2');
      }
    }

    // Product collection
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2';
    }

    // Banners
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2';
    }

    // Coupons
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2';
    }

    // App Metadata
    match /metadata/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2';
    }

    // Orders
    match /orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2');
      allow write: if request.auth != null && request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2';
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == 'gYOZP76EiJTCttGfbYerfcehvoy2';
    }
    
    // Block all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
