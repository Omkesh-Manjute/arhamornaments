rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if the user is an admin
    function isAdmin() {
      // Note: In storage rules, we can't easily check Firestore data without custom claims
      // For now, we rely on authenticated check and path matching
      return request.auth != null;
    }

    // Product images: public read, admin write
    match /products/{productId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null; // Refine this with custom claims if possible
    }
    
    // User avatars: public read (for social features), owner write
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Banners and UI assets: public read, admin write
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /categories/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
